# ─────────────────────────────────────────────────────────────
# Supabase connection (OPTIONAL)
#
# Leave these blank/unset to run the app fully LOCAL (data stored
# in your browser's localStorage, seeded with sample tasks).
#
# To switch to the Supabase cloud database:
#   1. Create a project at https://supabase.com
#   2. Run supabase/schema.sql in the Supabase SQL editor
#   3. Copy this file to ".env" and paste your Project URL + anon key
#   4. Restart the dev server (npm run dev)
#
# The app auto-detects these vars: present = Supabase, absent = local.
# ─────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────
# monday.com lookup (OPTIONAL) — the "Find on monday.com" button in the
# New Task dialog. Set to 1 to show the button. Requires Supabase (the
# lookup runs through the `monday-search` Edge Function) AND that function
# deployed with its MONDAY_* secrets set. See supabase/functions/monday-search.
# ─────────────────────────────────────────────────────────────
VITE_MONDAY_LOOKUP=
